<script>
  // Current date
  document.getElementById('currentDate').textContent = new Date().toLocaleDateString('en-IN', {weekday:'long',year:'numeric',month:'long',day:'numeric'});

  // Navigation
  function showPage(id) {
    document.querySelectorAll('.page').forEach(p => p.classList.remove('active'));
    document.querySelectorAll('.nav-item').forEach(n => n.classList.remove('active'));
    document.getElementById('page-' + id).classList.add('active');
    document.querySelectorAll('.nav-item').forEach(n => {
      if(n.getAttribute('onclick') && n.getAttribute('onclick').includes("'"+id+"'")) n.classList.add('active');
    });
    const titles = {dashboard:'Dashboard',attendance:'Attendance',result:'Results',fees:'Fee Management',feedback:'Feedback',timetable:'Timetable',notices:'Notice Board',profile:'My Profile'};
    document.getElementById('pageTitle').textContent = titles[id] || id;
    window.scrollTo(0,0);
  }

  // Star rating
  function rate(id, val) {
    const stars = document.querySelectorAll('#'+id+' .star');
    stars.forEach((s,i) => s.classList.toggle('active', i < val));
  }

  // Submit feedback
  function submitFeedback() {
    const btn = event.target;
    btn.textContent = '✓ Submitted!';
    btn.style.background = 'var(--accent3)';
    setTimeout(() => { btn.textContent = '✓ Submit Feedback'; btn.style.background = ''; }, 2000);
  }

  // Build grade chart on dashboard
  const subjects = [
    {name:'DSA', marks:92, color:'var(--accent)'},
    {name:'DBMS', marks:85, color:'var(--accent2)'},
    {name:'OS', marks:76, color:'var(--accent3)'},
    {name:'Math', marks:92, color:'var(--accent4)'},
    {name:'Phy', marks:70, color:'var(--accent5)'},
    {name:'Eng', marks:87, color:'#a78bfa'}
  ];
  const chartWrap = document.getElementById('gradeChartWrap');
  subjects.forEach(s => {
    const wrap = document.createElement('div'); wrap.className = 'grade-bar-wrap';
    const val = document.createElement('div'); val.className = 'grade-val'; val.textContent = s.marks;
    const bar = document.createElement('div'); bar.className = 'grade-bar';
    bar.style.height = (s.marks * 1.0) + 'px';
    bar.style.background = `linear-gradient(180deg, ${s.color}, ${s.color}44)`;
    const lbl = document.createElement('div'); lbl.className = 'grade-label'; lbl.textContent = s.name;
    wrap.appendChild(val); wrap.appendChild(bar); wrap.appendChild(lbl);
    chartWrap.appendChild(wrap);
  });
</script>
